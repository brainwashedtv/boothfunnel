# Copy to .env.local for local dev. Set the same vars in Vercel project settings for production.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs — create products + prices in Stripe dashboard, paste IDs here.
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_GROWTH=price_replace_me
STRIPE_PRICE_MULTI=price_replace_me

# Where Stripe Checkout redirects after success/cancel.
PUBLIC_BASE_URL=http://localhost:3000

# Optional: where contact-form submissions are forwarded.
CONTACT_FORWARD_EMAIL=hello@boothfunnel.com
